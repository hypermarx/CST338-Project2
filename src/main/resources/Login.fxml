<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="LoginController">
   <children>
    <Button layoutX="382.0" layoutY="260.0" mnemonicParsing="false" onMouseClicked="#login" text="Sign in">
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor></Button>
      <PasswordField fx:id="passwordField" layoutX="167.0" layoutY="218.0" prefHeight="25.0" prefWidth="268.0" promptText="Password">
         <cursor>
            <Cursor fx:constant="TEXT" />
         </cursor></PasswordField>
      <TextField fx:id="usernameField" layoutX="167.0" layoutY="175.0" prefHeight="25.0" prefWidth="268.0" promptText="Username">
         <cursor>
            <Cursor fx:constant="TEXT" />
         </cursor></TextField>
      <Label layoutX="159.0" layoutY="104.0" prefHeight="54.0" prefWidth="287.0" text="Quizweaver" textFill="#19191b">
         <font>
            <Font name="Trajan Pro" size="42.0" />
         </font>
      </Label>
      <Label layoutX="451.0" layoutY="161.0" prefHeight="54.0" prefWidth="132.0" rotate="26.6" text="Pretty graphic design coming when I truly learn frontend!" textAlignment="CENTER" wrapText="true">
         <font>
            <Font name="Verdana" size="12.0" />
         </font>
      </Label>
      <VBox layoutX="330.0" layoutY="285.0" prefHeight="88.0" prefWidth="157.0">
         <children>
            <Label fx:id="wrongDetails" prefHeight="17.0" prefWidth="155.0" text="Wrong username/password" textFill="#e11010" />
            <Hyperlink onMouseClicked="#toRegister" text="Register new user..." />
         </children>
      </VBox>
   </children>
</AnchorPane>
