<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="CreateQuizController">
   <children>
      <ScrollPane layoutX="28.0" layoutY="57.0" prefHeight="307.0" prefWidth="538.0">
         <content>
            <VBox fx:id="questionBox" alignment="TOP_CENTER" prefHeight="303.0" prefWidth="540.0">
               <children>
                  <Button fx:id="newQuestion" mnemonicParsing="false" onAction="#addQuestion" text="+ Add Question" textAlignment="CENTER">
                     <font>
                        <Font size="23.0" />
                     </font>
                  </Button>
               </children>
            </VBox>
         </content>
      </ScrollPane>
      <HBox layoutX="31.0" layoutY="14.0" prefHeight="25.0" prefWidth="538.0" spacing="15.0">
         <children>
            <Button fx:id="saveName" mnemonicParsing="false" onAction="#saveName" prefHeight="25.0" prefWidth="77.0" text="Save name" />
            <TextField fx:id="nameEntry" prefHeight="25.0" prefWidth="445.0" promptText="Enter quiz name...">
               <font>
                  <Font name="Calibri" size="12.0" />
               </font></TextField>
         </children>
      </HBox>
      <Button fx:id="backBtn" layoutX="28.0" layoutY="364.0" mnemonicParsing="false" onAction="#back" text="Back" />
   </children>
</AnchorPane>
