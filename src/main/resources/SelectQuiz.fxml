<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="SelectQuizController">
   <children>
      <Label layoutX="201.0" layoutY="14.0" text="Your Quizzes">
         <font>
            <Font name="Calibri" size="38.0" />
         </font>
      </Label>
      <ScrollPane layoutX="43.0" layoutY="67.0" prefHeight="302.0" prefWidth="516.0">
         <content>
            <VBox fx:id="buttonContainer" alignment="TOP_CENTER" prefHeight="322.0" prefWidth="517.0" spacing="20.0">
               <children>
                  <Button fx:id="createQuizBtn" mnemonicParsing="false" onAction="#createQuiz" prefHeight="66.0" prefWidth="447.0" text="+ Create Quiz" textAlignment="CENTER">
                     <font>
                        <Font name="Trajan Pro" size="29.0" />
                     </font>
                  </Button>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</AnchorPane>
