<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="RegisterController">
   <children>
      <VBox alignment="TOP_RIGHT" layoutX="174.0" layoutY="117.0" prefHeight="162.0" prefWidth="343.0" spacing="20.0">
         <children>
            <TextField fx:id="usernameField" prefHeight="25.0" prefWidth="269.0" />
            <PasswordField fx:id="passwordField" />
            <PasswordField fx:id="confirmPassword" />
            <Button fx:id="createUser" mnemonicParsing="false" onAction="#createUser" text="Create User">
               <font>
                  <Font name="Calibri" size="12.0" />
               </font></Button>
         </children>
      </VBox>
      <VBox alignment="TOP_RIGHT" layoutX="30.0" layoutY="124.0" prefHeight="200.0" prefWidth="129.0" spacing="20.0">
         <children>
            <Label alignment="CENTER_RIGHT" text="Username">
               <font>
                  <Font name="Cambria" size="15.0" />
               </font>
            </Label>
            <Label text="Password">
               <font>
                  <Font name="Cambria" size="15.0" />
               </font>
            </Label>
            <Label prefHeight="10.0" prefWidth="119.0" text="Confirm password" textAlignment="RIGHT" wrapText="true">
               <font>
                  <Font name="Cambria" size="15.0" />
               </font>
            </Label>
         </children>
      </VBox>
      <VBox alignment="TOP_RIGHT" layoutX="277.0" layoutY="279.0" prefHeight="54.0" prefWidth="240.0">
         <children>
            <Label fx:id="lengthError" text="Password must be at least 8 characters" textFill="#f52424" />
            <Label fx:id="confirmError" text="Password and confirmation must match" textFill="#ff0808" />
         </children>
      </VBox>
      <Button fx:id="back" layoutX="30.0" layoutY="353.0" mnemonicParsing="false" onAction="#back" text="Back to login" />
   </children>
</AnchorPane>
